[debug] [2026-06-08T00:02:01.716Z] <<< [apiv2][body] POST https://firebaserules.googleapis.com/v1/projects/cafeteria-vendas-gustavo/rulesets {"name":"projects/cafeteria-vendas-gustavo/rulesets/95ce758c-e650-4bc2-8ea6-0a5acb551e0b","source":{"files":[{"content":"rules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n    match /orders/{orderId} {\n      allow create: if isValidOrder();\n      allow read, update, delete: if false;\n    }\n\n    function isValidOrder() {\n      return request.resource.data.keys().hasAll([\n        'id',\n        'name',\n        'phone',\n        'fulfillment',\n        'payment',\n        'items',\n        'subtotal',\n        'deliveryFee',\n        'total',\n        'status',\n        'createdAt'\n      ])\n      && request.resource.data.keys().hasOnly([\n        'id',\n        'name',\n        'phone',\n        'address',\n        'fulfillment',\n        'payment',\n        'notes',\n        'changeFor',\n        'items',\n        'subtotal',\n        'deliveryFee',\n        'total',\n        'status',\n        'createdAt'\n      ])\n      && request.resource.data.status == 'novo'\n      && request.resource.data.name is string\n      && request.resource.data.phone is string\n      && request.resource.data.fulfillment in ['delivery', 'pickup']\n      && request.resource.data.payment in ['pix', 'card', 'cash']\n      && request.resource.data.items is list\n      && request.resource.data.total is number;\n    }\n  }\n}\n","name":"firestore.rules"}]},"createTime":"2026-06-08T00:02:01.742952Z","metadata":{"services":["cloud.firestore"]}}
