[debug] [2026-06-23T16:34:35.491Z] <<< [apiv2][body] POST https://firebaserules.googleapis.com/v1/projects/cafeteria-vendas-gustavo/rulesets {"name":"projects/cafeteria-vendas-gustavo/rulesets/ebddc110-ceb0-4723-87cc-d315370cd64d","source":{"files":[{"content":"rules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n    match /users/{userId} {\n      allow create: if request.auth != null\n        && request.auth.uid == userId\n        && request.resource.data.keys().hasOnly(['name', 'email', 'createdAt', 'updatedAt'])\n        && request.resource.data.name is string\n        && request.resource.data.email == request.auth.token.email;\n      allow read: if request.auth != null && request.auth.uid == userId;\n      allow update: if request.auth != null\n        && request.auth.uid == userId\n        && request.resource.data.email == resource.data.email;\n      allow delete: if false;\n    }\n\n    match /carts/{userId} {\n      allow read, create, update, delete: if request.auth != null\n        && request.auth.uid == userId;\n    }\n\n    match /orders/{orderId} {\n      allow create: if isValidOrder();\n      allow read, update, delete: if false;\n    }\n\n    function isValidOrder() {\n      return request.resource.data.keys().hasAll([\n        'id',\n        'name',\n        'phone',\n        'fulfillment',\n        'payment',\n        'items',\n        'subtotal',\n        'deliveryFee',\n        'total',\n        'status',\n        'createdAt'\n      ])\n      && request.resource.data.keys().hasOnly([\n        'id',\n        'name',\n        'phone',\n        'address',\n        'fulfillment',\n        'payment',\n        'notes',\n        'changeFor',\n        'items',\n        'subtotal',\n        'deliveryFee',\n        'total',\n        'status',\n        'createdAt'\n      ])\n      && request.resource.data.status == 'novo'\n      && request.resource.data.name is string\n      && request.resource.data.phone is string\n      && request.resource.data.fulfillment in ['delivery', 'pickup']\n      && request.resource.data.payment in ['pix', 'card', 'cash']\n      && request.resource.data.items is list\n      && request.resource.data.total is number;\n    }\n  }\n}\n","name":"firestore.rules"}]},"createTime":"2026-06-23T16:34:34.038623Z","metadata":{"services":["cloud.firestore"]}}
