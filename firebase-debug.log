[debug] [2026-06-07T23:24:12.467Z] <<< [apiv2][body] POST https://firebaserules.googleapis.com/v1/projects/helpdesk-fire-base/rulesets {"name":"projects/helpdesk-fire-base/rulesets/08acb48c-8ad4-48ea-b3bd-ab85eaf1dc5e","source":{"files":[{"content":"rules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n    match /orders/{orderId} {\n      allow create: if isValidOrder();\n      allow read, update, delete: if false;\n    }\n\n    function isValidOrder() {\n      return request.resource.data.keys().hasAll([\n        'id',\n        'name',\n        'phone',\n        'fulfillment',\n        'payment',\n        'items',\n        'subtotal',\n        'deliveryFee',\n        'total',\n        'status',\n        'createdAt'\n      ])\n      && request.resource.data.keys().hasOnly([\n        'id',\n        'name',\n        'phone',\n        'address',\n        'fulfillment',\n        'payment',\n        'notes',\n        'changeFor',\n        'items',\n        'subtotal',\n        'deliveryFee',\n        'total',\n        'status',\n        'createdAt'\n      ])\n      && request.resource.data.status == 'novo'\n      && request.resource.data.name is string\n      && request.resource.data.phone is string\n      && request.resource.data.fulfillment in ['delivery', 'pickup']\n      && request.resource.data.payment in ['pix', 'card', 'cash']\n      && request.resource.data.items is list\n      && request.resource.data.total is number;\n    }\n  }\n}\n","name":"firestore.rules"}]},"createTime":"2026-06-07T23:24:12.550047Z","metadata":{"services":["cloud.firestore"]}}
