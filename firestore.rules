rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow create: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.keys().hasOnly(['name', 'email', 'createdAt', 'updatedAt'])
        && request.resource.data.name is string
        && request.resource.data.email == request.auth.token.email;
      allow read: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.email == resource.data.email;
      allow delete: if false;
    }

    match /carts/{userId} {
      allow read, create, update, delete: if request.auth != null
        && request.auth.uid == userId;
    }

    match /orders/{orderId} {
      allow create: if isValidOrder();
      allow read, update, delete: if false;
    }

    function isValidOrder() {
      return request.resource.data.keys().hasAll([
        'id',
        'name',
        'phone',
        'fulfillment',
        'payment',
        'items',
        'subtotal',
        'deliveryFee',
        'total',
        'status',
        'createdAt'
      ])
      && request.resource.data.keys().hasOnly([
        'id',
        'name',
        'phone',
        'address',
        'fulfillment',
        'payment',
        'notes',
        'changeFor',
        'items',
        'subtotal',
        'deliveryFee',
        'total',
        'status',
        'createdAt'
      ])
      && request.resource.data.status == 'novo'
      && request.resource.data.name is string
      && request.resource.data.phone is string
      && request.resource.data.fulfillment in ['delivery', 'pickup']
      && request.resource.data.payment in ['pix', 'card', 'cash']
      && request.resource.data.items is list
      && request.resource.data.total is number;
    }
  }
}
